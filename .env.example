# =============================================================================
# LevelPro — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# Local: points to Docker container on port 5433
# Cloud: swap with Railway / Supabase connection string
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://levelpro:levelpro_secret@localhost:5433/levelpro?schema=public"

# -----------------------------------------------------------------------------
# NextAuth.js v5
# AUTH_SECRET: Generate with `openssl rand -base64 32`
# AUTH_URL: Your app's base URL
# -----------------------------------------------------------------------------
AUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# -----------------------------------------------------------------------------
# Google OAuth Provider
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# Drupal Headless CMS
# Local: points to Docker container on port 8888
# Cloud: swap with your Drupal host URL
# -----------------------------------------------------------------------------
DRUPAL_BASE_URL="http://localhost:8888"

# -----------------------------------------------------------------------------
# App URL (used for email links, og:meta, etc.)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email / SMTP (for verification emails)
# Leave empty for local dev — emails will print to console
# For production, use Resend, SendGrid, or any SMTP provider
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT=""
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="LevelPro <contact@levelproedu.com>"

# Required for inbox OTP delivery through Resend. Verify EMAIL_FROM in Resend first.
RESEND_API_KEY=""
